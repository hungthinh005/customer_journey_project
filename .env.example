# ============================================================
# Customer Journey Project - Environment Configuration
# Copy to .env and adjust values. NEVER commit the real .env.
# ============================================================

# ---- OpenAI / Agent ----
OPENAI_API_KEY=
AGENT_LLM_MODEL=gpt-4o-mini
AGENT_TEMPERATURE=0.3
# Max discount (fraction) the agent is allowed to offer, e.g. 0.20 = 20%
AGENT_MAX_DISCOUNT=0.20
# Do not contact the same customer more than once within this many days
AGENT_FREQUENCY_CAP_DAYS=7
# If true, the agent composes messages but does NOT actually send email
AGENT_DRY_RUN=false

# ---- Postgres (serving + Airflow + MLflow metadata) ----
POSTGRES_USER=cjp
POSTGRES_PASSWORD=cjp_password
POSTGRES_DB=cjp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# App serving DB URL (used by API, agent, segmentation, loaders)
DATABASE_URL=postgresql+psycopg2://cjp:cjp_password@postgres:5432/cjp

# ---- SMTP / Notifications (MailHog in local prod simulation) ----
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=retention@customer-journey.local
SMTP_FROM_NAME=Customer Journey Retention

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=churn-prevention

# ---- API ----
API_KEY=local-dev-key
API_BASE_URL=http://churn-api:8000

# ---- Airflow ----
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-prod
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
